---
import { newsletter } from '../config/site';
import { withBase } from '../utils/url';

const rssPath = withBase('/rss.xml');
const dialogId = Astro.props.dialogId ?? 'subscribe-dialog';
---

<>
  <button
    class="rounded-full border border-border px-4 py-2 text-sm transition hover:border-primary"
    data-subscribe-open={dialogId}
    type="button"
  >
    订阅
  </button>

  <dialog
    class="w-[min(92vw,34rem)] rounded-[1.75rem] border border-border bg-white p-0 text-foreground shadow-[0_32px_100px_rgba(15,23,42,0.28)] backdrop:bg-slate-950/55 dark:bg-slate-900"
    id={dialogId}
  >
    <div class="overflow-hidden rounded-[1.75rem]">
      <div class="border-b border-border bg-[radial-gradient(circle_at_top_left,_rgba(59,130,246,0.14),_transparent_38%),linear-gradient(135deg,_rgba(248,250,252,0.95),_rgba(241,245,249,0.72))] px-6 py-6 dark:bg-[radial-gradient(circle_at_top_left,_rgba(96,165,250,0.14),_transparent_42%),linear-gradient(135deg,_rgba(15,23,42,0.98),_rgba(15,23,42,0.82))] sm:px-7">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.28em] text-slate-500 dark:text-slate-400">
              Subscribe
            </p>
            <h2 class="mt-3 text-2xl font-semibold text-foreground">订阅方式</h2>
            <p class="mt-2 max-w-xl text-sm leading-6 text-slate-600 dark:text-slate-300">
              {newsletter.description}
            </p>
          </div>
          <button
            aria-label="关闭订阅窗口"
            class="rounded-full border border-border px-3 py-1.5 text-sm transition hover:border-primary"
            data-subscribe-close={dialogId}
            type="button"
          >
            关闭
          </button>
        </div>
      </div>

      <div class="space-y-5 px-6 py-6 sm:px-7">
        <div class="rounded-[1.5rem] border border-border bg-slate-50/90 p-4 dark:bg-slate-950/60">
          <div class="text-sm font-semibold text-foreground">RSS Feed</div>
          <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">
            复制下面这个地址到 Feedly、Inoreader、Reeder、NetNewsWire 之类的阅读器里即可。
            如果浏览器直接打开后看到 XML 文本，那是正常的。
          </p>
          <div class="mt-4 rounded-2xl border border-border bg-white px-4 py-3 font-mono text-sm text-slate-700 dark:bg-slate-900 dark:text-slate-200">
            <span data-rss-value>{rssPath}</span>
          </div>
          <div class="mt-4 flex flex-wrap gap-3">
            <button
              class="rounded-2xl bg-slate-950 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200"
              data-copy-rss={dialogId}
              type="button"
            >
              复制 RSS 地址
            </button>
            <a
              class="rounded-2xl border border-border px-4 py-2.5 text-sm transition hover:border-primary"
              href={rssPath}
              target="_blank"
              rel="noreferrer"
            >
              直接打开 Feed
            </a>
          </div>
          <p
            class="mt-3 text-xs text-slate-500 dark:text-slate-400"
            data-copy-feedback={dialogId}
          >
            纯 RSS，无账号，无邮件打扰。
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl border border-border px-4 py-4">
            <div class="text-sm font-semibold text-foreground">1. 复制地址</div>
            <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">
              使用上面的按钮复制 RSS 链接。
            </p>
          </div>
          <div class="rounded-2xl border border-border px-4 py-4">
            <div class="text-sm font-semibold text-foreground">2. 打开阅读器</div>
            <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">
              在常用 RSS 阅读器中选择添加订阅源。
            </p>
          </div>
          <div class="rounded-2xl border border-border px-4 py-4">
            <div class="text-sm font-semibold text-foreground">3. 自动收更新</div>
            <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">
              后续新文章会自动进入你的阅读列表。
            </p>
          </div>
        </div>
      </div>
    </div>
  </dialog>

  <script is:inline define:vars={{ dialogId, rssPath }}>
    const dialog = document.getElementById(dialogId);
    const openButton = document.querySelector(`[data-subscribe-open="${dialogId}"]`);
    const closeButton = document.querySelector(`[data-subscribe-close="${dialogId}"]`);
    const copyButton = document.querySelector(`[data-copy-rss="${dialogId}"]`);
    const feedback = document.querySelector(`[data-copy-feedback="${dialogId}"]`);

    if (dialog instanceof HTMLDialogElement) {
      openButton?.addEventListener('click', () => {
        dialog.showModal();
      });

      closeButton?.addEventListener('click', () => {
        dialog.close();
      });

      dialog.addEventListener('click', (event) => {
        const rect = dialog.getBoundingClientRect();
        const inside =
          rect.top <= event.clientY &&
          event.clientY <= rect.top + rect.height &&
          rect.left <= event.clientX &&
          event.clientX <= rect.left + rect.width;
        if (!inside) dialog.close();
      });
    }

    copyButton?.addEventListener('click', async () => {
      const absoluteRssUrl = new URL(rssPath, window.location.origin).href;
      try {
        await navigator.clipboard.writeText(absoluteRssUrl);
        if (feedback) feedback.textContent = `已复制: ${absoluteRssUrl}`;
      } catch {
        if (feedback) feedback.textContent = `复制失败，请手动复制: ${absoluteRssUrl}`;
      }
    });
  </script>
</>
